{{ 'product-grid.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign fc_collection = collections[section.settings.collection]
  if fc_collection == blank
    assign fc_collection = collections.all
  endif
-%}

<section class="featured-collection">
  <div class="container">
    <div class="featured-collection__header">
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if fc_collection.url -%}
        <a href="{{ fc_collection.url }}" class="featured-collection__view-all">View All &rarr;</a>
      {%- endif -%}
    </div>

    <div class="product-grid product-grid--{{ section.settings.columns_desktop }}-col">
      {%- for product in fc_collection.products limit: section.settings.products_to_show -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p class="featured-collection__empty">Add products to this collection to feature them here.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "shopify-section--featured-collection",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Fresh Off the Rack" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 8 },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    }
  ],
  "presets": [
    { "name": "Featured Collection" }
  ]
}
{% endschema %}
