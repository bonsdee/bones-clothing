{{ 'header.css' | asset_url | stylesheet_tag }}

<header class="site-header" data-header>
  <div class="site-header__inner container">
    <button class="site-header__menu-toggle" data-mobile-menu-toggle aria-expanded="false" aria-controls="MobileMenu">
      <span></span><span></span><span></span>
      <span class="visually-hidden">Menu</span>
    </button>

    <a href="{{ routes.root_url }}" class="site-header__logo">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 320 }}"
          alt="{{ shop.name }}"
          width="{{ section.settings.logo_width }}"
          height="{{ section.settings.logo_width | divided_by: section.settings.logo.aspect_ratio }}"
          loading="eager"
        >
      {%- else -%}
        <img
          class="site-header__logo-img"
          src="{{ 'logo.png' | asset_url }}"
          alt="{{ shop.name | default: 'Bones Clothing' }}"
          width="677"
          height="369"
          loading="eager"
        >
      {%- endif -%}
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul>
        {%- for link in section.settings.main_menu.links -%}
          <li>
            <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    <div class="site-header__actions">
      <a href="{{ routes.search_url }}" class="site-header__icon-link" aria-label="Search">
        {% render 'icon-search' %}
      </a>
      <a href="{{ routes.account_url }}" class="site-header__icon-link" aria-label="Account">
        {% render 'icon-account' %}
      </a>
      <button type="button" class="site-header__icon-link site-header__cart-toggle" data-cart-drawer-open aria-label="Open cart">
        {% render 'icon-bag' %}
        <span class="cart-count" data-cart-count>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

  <div id="MobileMenu" class="mobile-menu" data-mobile-menu hidden>
    <ul>
      {%- for link in section.settings.main_menu.links -%}
        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
      {%- endfor -%}
    </ul>
  </div>

  {%- if section.settings.announcement != blank -%}
    <div class="announcement-bar">
      <p>{{ section.settings.announcement }}</p>
    </div>
  {%- endif -%}
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "label": "Logo width", "min": 80, "max": 300, "step": 10, "default": 160, "unit": "px" },
    { "type": "link_list", "id": "main_menu", "label": "Menu", "default": "main-menu" },
    { "type": "text", "id": "announcement", "label": "Announcement bar text", "default": "FREE SHIPPING ON DROPS OVER $150 — LOCAL PICKUP AVAILABLE" }
  ]
}
{% endschema %}
