{{ 'restock-notify.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Only renders meaningfully when the current variant is sold out. Submits to the
  Drop & Restock Manager app via a Shopify App Proxy so merchants get a real
  waitlist entry (see app/server/src/routes/proxy.js). Falls back to a mailto
  hint if the proxy path isn't configured yet in a dev/theme-only context.
{%- endcomment -%}

<section class="restock-notify" data-restock-notify data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" {% unless product.selected_or_first_available_variant.available == false %}hidden{% endunless %}>
  <div class="container restock-notify__inner">
    <div class="restock-notify__text">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.subtext }}</p>
    </div>

    <form class="restock-notify__form" data-restock-form action="/apps/drop-waitlist/subscribe" method="post" novalidate>
      <input type="hidden" name="product_id" value="{{ product.id }}">
      <input type="hidden" name="variant_id" value="{{ product.selected_or_first_available_variant.id }}" data-restock-variant-input>
      <input type="hidden" name="shop" value="{{ shop.permanent_domain }}">
      <label class="visually-hidden" for="RestockEmail">Email address</label>
      <input type="email" id="RestockEmail" name="email" placeholder="you@email.com" required>
      <button type="submit">{{ 'products.product.notify_me' | t }}</button>
    </form>
    <p class="restock-notify__message" data-restock-message role="status" hidden></p>
  </div>
</section>

{% schema %}
{
  "name": "Restock Notify",
  "tag": "section",
  "class": "shopify-section--restock-notify",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Missed Your Size?" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Drop your email and we'll ping you the second this restocks. No spam, just heat." }
  ],
  "presets": [
    { "name": "Restock Notify" }
  ]
}
{% endschema %}
