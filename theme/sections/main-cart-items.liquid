{{ 'cart.css' | asset_url | stylesheet_tag }}

<section class="cart-page">
  <div class="container">
    <h1 class="cart-page__title">{{ 'general.cart.title' | t }}</h1>

    {%- if cart.item_count == 0 -%}
      <div class="cart-page__empty">
        <p>{{ 'general.cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--accent">Continue Shopping</a>
      </div>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-page__form" data-cart-form>
        <table class="cart-page__table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>{{ 'general.cart.quantity' | t }}</th>
              <th>Total</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {%- for item in cart.items -%}
              <tr class="cart-page__row" data-cart-item data-key="{{ item.key }}">
                <td class="cart-page__product">
                  <a href="{{ item.url }}" class="cart-page__image">
                    {%- if item.image -%}
                      <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.image.alt | escape }}" width="80" height="{{ 80 | divided_by: item.image.aspect_ratio }}">
                    {%- endif -%}
                  </a>
                  <div>
                    <a href="{{ item.url }}" class="cart-page__product-title">{{ item.product.title }}</a>
                    {%- if item.variant.title != 'Default Title' -%}
                      <p class="cart-page__variant">{{ item.variant.title }}</p>
                    {%- endif -%}
                  </div>
                </td>
                <td data-cart-item-price>{{ item.original_price | money }}</td>
                <td>
                  <input
                    type="number"
                    min="0"
                    class="cart-page__qty"
                    data-cart-qty-input
                    data-key="{{ item.key }}"
                    value="{{ item.quantity }}"
                    aria-label="Quantity for {{ item.product.title | escape }}"
                  >
                </td>
                <td data-cart-item-line-total>{{ item.final_line_price | money }}</td>
                <td>
                  <button type="button" class="cart-page__remove" data-cart-remove data-key="{{ item.key }}" aria-label="Remove {{ item.product.title | escape }}">&times;</button>
                </td>
              </tr>
            {%- endfor -%}
          </tbody>
        </table>

        <div class="cart-page__summary">
          <div class="cart-page__summary-line">
            <span>{{ 'general.cart.subtotal' | t }}</span>
            <span data-cart-subtotal>{{ cart.total_price | money }}</span>
          </div>
          <button type="submit" name="checkout" class="btn btn--accent cart-page__checkout">{{ 'general.cart.checkout' | t }}</button>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

<script src="{{ 'cart.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Cart items",
  "settings": []
}
{% endschema %}
