{{ 'collection-list.css' | asset_url | stylesheet_tag }}

<section class="collection-list">
  <div class="container">
    <div class="collection-list__header">
      <h1>{{ section.settings.heading | default: 'Shop by Collection' }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p>{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="collection-list__grid">
      {%- for collection in collections -%}
        {%- if collection.products_count > 0 or section.settings.show_empty -%}
          {%- liquid
            assign thumb_image = collection.image
            if thumb_image == blank
              assign thumb_image = collection.products.first.featured_image
            endif
          -%}
          <a href="{{ collection.url }}" class="collection-card">
            <span class="collection-card__media">
              {%- if thumb_image != blank -%}
                <img
                  class="collection-card__image"
                  src="{{ thumb_image | image_url: width: 600 }}"
                  alt="{{ collection.title | escape }}"
                  loading="lazy"
                  width="600"
                  height="450"
                >
              {%- else -%}
                <span class="collection-card__image collection-card__image--placeholder">No image yet</span>
              {%- endif -%}
            </span>
            <h3 class="collection-card__title">{{ collection.title }}</h3>
            <p class="collection-card__count">{{ collection.products_count }} item{% if collection.products_count != 1 %}s{% endif %}</p>
          </a>
        {%- endif -%}
      {%- else -%}
        <p class="collection-list__empty">No collections to show yet.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "tag": "section",
  "class": "shopify-section--collection-list",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Collection" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "checkbox", "id": "show_empty", "label": "Show collections with no products", "default": false }
  ],
  "presets": [
    { "name": "Collection list" }
  ]
}
{% endschema %}
