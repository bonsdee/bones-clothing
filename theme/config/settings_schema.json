    "settings": [
      { "type": "color", "id": "color_background", "label": "Background", "default": "#0d0d0d" },
      { "type": "color", "id": "color_text", "label": "Text", "default": "#f5f3ee" },
      { "type": "color", "id": "color_accent", "label": "Accent (Bones Yellow)", "default": "#f4d21c" },
      { "type": "color", "id": "color_muted", "label": "Muted surfaces", "default": "#1a1a1a" },
      { "type": "color", "id": "color_border", "label": "Borders", "default": "#333333" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "heading_font_stack",
        "label": "Heading font",
        "options": [
          { "value": "'Helvetica Neue', Arial, sans-serif", "label": "Neue Sans (system)" },
          { "value": "'Courier New', monospace", "label": "Mono / Stencil feel" }
