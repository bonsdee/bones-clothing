# Shopify Partner Dashboard > App > Client credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Comma-separated Admin API scopes requested during OAuth
SCOPES=read_products,write_products,read_inventory,write_inventory,read_orders

# Publicly reachable URL for this server (ngrok/cloudflared URL in dev,
# your real domain in production). No trailing slash.
SHOPIFY_APP_URL=https://your-tunnel-url.trycloudflare.com

# MySQL connection string. Drizzle + mysql2 both read this.
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@127.0.0.1:3306/drop_restock_manager

PORT=8080
NODE_ENV=development
